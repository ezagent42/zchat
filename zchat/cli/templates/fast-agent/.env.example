# Auto-injected by zchat
AGENT_NAME={{agent_name}}
IRC_SERVER={{irc_server}}
IRC_PORT={{irc_port}}
IRC_CHANNELS={{irc_channels}}
IRC_TLS={{irc_tls}}
IRC_PASSWORD={{irc_password}}
# Auth token for IRC SASL (set by zchat when OIDC is configured)
IRC_AUTH_TOKEN={{irc_auth_token}}
AUTH_TOKEN_FILE={{auth_token_file}}
WORKSPACE={{workspace}}
ZCHAT_PROJECT_DIR={{zchat_project_dir}}

# User configuration
ANTHROPIC_API_KEY=

# MCP server command — override for dev (e.g., "uv run --project /path zchat-channel")
MCP_SERVER_CMD=zchat-agent-mcp

# Channel server package directory (resolved by zchat agent create)
CHANNEL_PKG_DIR={{channel_pkg_dir}}

# voice_bridge HTTP /issue endpoint — enables voice_link MCP tool
# 仅 fast-agent 需要；其他 template 不设此 var → agent_mcp 不暴露 voice_link
VOICE_BRIDGE_ISSUE_URL=http://127.0.0.1:8787/issue
